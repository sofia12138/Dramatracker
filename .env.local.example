# ============================================================
# DramaTracker 环境变量模板
# 复制为 .env.local 并填写实际值
# ============================================================

# ── 数据库模式 ────────────────────────────────────────────────
# true  = 使用 MySQL（新架构，服务器部署时启用）
# false = 使用 SQLite（本地开发默认）
USE_MYSQL=false

# ── MySQL 连接（USE_MYSQL=true 时必填）────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=dramatracker
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=dramatracker

# ── 同步 API Token（本地抓取脚本推送数据用）────────────────────
# 生成方式：openssl rand -hex 32
SYNC_API_TOKEN=your_sync_token_here

# ── 认证 & JWT ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── AI 分析（可选）───────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── DataEye 抓取 Cookie（可选）────────────────────────────────
DT_DATAEYE_COOKIE=
